{
  "name": "@louis-innovations/sadad-shopify",
  "version": "1.0.0",
  "description": "SADAD Payment Gateway integration for Shopify stores — standalone Node.js/Express server",
  "main": "dist/server.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node --watch dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "sadad",
    "shopify",
    "payment",
    "gateway",
    "qatar",
    "express",
    "typescript"
  ],
  "author": "Louis Innovations (www.louis-innovations.com)",
  "license": "MIT",
  "homepage": "https://github.com/louis-innovations/sadad-shopify#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/louis-innovations/sadad-shopify.git"
  },
  "bugs": {
    "url": "https://github.com/louis-innovations/sadad-shopify/issues"
  },
  "files": [
    "dist",
    "templates",
    "config",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "Dockerfile",
    "docker-compose.yml",
    ".env.example"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@louis-innovations/sadad-js-sdk": "file:../sadad-js-sdk",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
