# SADAD Shopify Integration — Express Server
# Built by Louis Innovations (www.louis-innovations.com)
# Copy this file to .env and fill in your real values.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=production

# ---------------------------------------------------------------------------
# SADAD Credentials
# Obtain these from the SADAD merchant portal: https://sadadqa.com
# ---------------------------------------------------------------------------
SADAD_MERCHANT_ID=1234567
SADAD_SECRET_KEY=your-sadad-secret-key-here
SADAD_WEBSITE=YOURWEBSITE

# test | live
SADAD_ENVIRONMENT=test

# eng | arb
SADAD_LANGUAGE=eng

# v1.1 | v2.1 | v2.2
SADAD_CHECKOUT_VERSION=v1.1

# ---------------------------------------------------------------------------
# SADAD Endpoint URLs
# These must be the PUBLIC URLs of THIS server that SADAD can reach.
# ---------------------------------------------------------------------------
SADAD_CALLBACK_URL=https://your-sadad-server.example.com/sadad/callback
SADAD_WEBHOOK_URL=https://your-sadad-server.example.com/sadad/webhook

# ---------------------------------------------------------------------------
# Shopify
# Generate an Admin API access token in Shopify Admin >
# Settings > Apps and sales channels > Develop apps
# Scopes needed: read_orders, write_orders
# ---------------------------------------------------------------------------
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret

# ---------------------------------------------------------------------------
# Post-payment Redirects
# Where to send customers after payment succeeds or fails.
# ---------------------------------------------------------------------------
SUCCESS_REDIRECT_URL=https://your-store.myshopify.com/pages/payment-success
FAILURE_REDIRECT_URL=https://your-store.myshopify.com/pages/payment-failure
